# ============================================================
# TraderToolsTH Backend — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# ห้าม commit ไฟล์ .env (ถูก ignore อยู่แล้วใน .gitignore)
# ============================================================

# ---- OpenAI (Phase 3 — ยังไม่ใช้ใน Phase 2) ----
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# ---- Pexels (Phase 4) ----
PEXELS_API_KEY=
# HTTP timeout ใน ms สำหรับ Pexels API
PEXELS_HTTP_TIMEOUT_MS=15000
# จำนวน retry เมื่อ Pexels API ล้มเหลว
PEXELS_HTTP_RETRIES=2
# หน่วงระหว่าง keyword (ms) เพื่อ rate limit (Pexels free: 200 req/hr)
PEXELS_KEYWORD_DELAY_MS=500

# ---- Storage ----
DATABASE_URL=file:./data/news.db

# ---- Scheduler ----
NEWS_INTERVAL_MINUTES=60
SCHEDULER_ENABLED=false
RUN_ON_START=false
AUTO_PUBLISH=false
NEWS_MAX_PER_RUN=5

# ---- Website/API server ----
SERVER_HOST=127.0.0.1
PORT=3000
SITE_VERSION=2
# หากเว้นว่าง Admin API จะปิดใช้งาน
ADMIN_TOKEN=

# ---- Scraper tuning ----
# จำนวนข่าวสูงสุดต่อหน้าหมวดที่จะดึงในแต่ละรอบ
KITCO_MAX_PER_SECTION=20
# อายุข่าวสูงสุดที่จะรับ (ชั่วโมง) — ข่าวเก่ากว่านี้จะถูกตัดออก
KITCO_MAX_AGE_HOURS=48
# หน่วงเวลาระหว่างการเปิดบทความ (ms) เพื่อ rate limit
KITCO_ARTICLE_DELAY_MS=1500
# HTTP timeout (ms)
KITCO_HTTP_TIMEOUT_MS=20000
# จำนวน retry เมื่อ request ล้มเหลว
KITCO_HTTP_RETRIES=2

# ---- Logging ----
LOG_LEVEL=info

# ============================================================
# Phase 12 — Economic Calendar (Forex Factory)
# ------------------------------------------------------------
# กฎ: ดึงข้อมูลจาก backend เท่านั้น, ใช้ public JSON export
# (ไม่ใช่ bypass CAPTCHA/Cloudflare/login/robots)
# ============================================================
# JSON export สาธารณะของ Forex Factory (อัปเดตอัตโนมัติรายสัปดาห์)
FOREX_FACTORY_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
# ช่วงซิงก์อัตโนมัติ (วินาที) — ค่าเริ่มต้น 300 = 5 นาที
CALENDAR_SYNC_INTERVAL_SECONDS=300
# เปิด/ปิดระบบปฏิทินเศรษฐกิจ
CALENDAR_ENABLED=true
# ระยะเวลาที่ cache ถือว่าเริ่มเก่า (วินาที) — ค่าเริ่มต้น 1800 = 30 นาที
CALENDAR_STALE_AFTER_SECONDS=1800
# HTTP timeout (ms) สำหรับดึง calendar
CALENDAR_HTTP_TIMEOUT_MS=15000
# จำนวน retry เมื่อ source ล้มเหลว
CALENDAR_HTTP_RETRIES=2
# อายุ event สูงสุดที่จะเก็บใน cache (ชั่วโมง) — ค่าเริ่มต้น 168 = 7 วัน
CALENDAR_MAX_EVENT_AGE_HOURS=168

# ============================================================
# Phase 13 — Market Ticker (watchlist prices)
# ------------------------------------------------------------
# กฎ: ดึงข้อมูลฝั่ง backend เท่านั้น ห้ามให้ browser เรียก third-party โดยตรง
# ใช้ free public sources เท่านั้น (ไม่ต้องการ API key ใดๆ)
# - gold-api.com     → XAUUSD, XAGUSD (metals)
# - open.er-api.com  → EURUSD, GBPUSD, USDJPY (forex)
# - coingecko.com    → BTCUSD (crypto)
# - DXY: ไม่มีแหล่งฟรีที่น่าเชื่อถือ → unavailable (ไม่ใช่ข้อมูลปลอม)
# ============================================================
# เปิด/ปิดระบบ Market Ticker
MARKET_ENABLED=true
# cache ระยะสั้น (วินาที) — ต้อง ≥ 30 ตาม requirement (กัน hammer source)
MARKET_CACHE_SECONDS=60
# ระยะเวลาที่ cache ถือว่าเริ่มเก่า (วินาที) — source ล้มเหลว → ยังคืน cache แต่ stale=true
MARKET_STALE_AFTER_SECONDS=600
# ช่วงซิงก์อัตโนมัติ (วินาที) — ค่าเริ่มต้น 60
MARKET_SYNC_INTERVAL_SECONDS=60
# HTTP timeout (ms) สำหรับดึงราคาต่อ symbol
MARKET_FETCH_TIMEOUT_MS=8000
# (optional) override symbols: comma-separated เช่น XAUUSD,XAGUSD,EURUSD
# เว้นว่าง = ใช้ default 7 symbols (XAUUSD XAGUSD EURUSD GBPUSD USDJPY BTCUSD DXY)
MARKET_SYMBOLS=
