# ============================================================
# TraderToolsTH Backend — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# ห้าม commit ไฟล์ .env (ถูก ignore อยู่แล้วใน .gitignore)
# ============================================================

# ---- OpenAI (Phase 3 — ยังไม่ใช้ใน Phase 2) ----
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# ---- Pexels (Phase 4) ----
PEXELS_API_KEY=
# HTTP timeout ใน ms สำหรับ Pexels API
PEXELS_HTTP_TIMEOUT_MS=15000
# จำนวน retry เมื่อ Pexels API ล้มเหลว
PEXELS_HTTP_RETRIES=2
# หน่วงระหว่าง keyword (ms) เพื่อ rate limit (Pexels free: 200 req/hr)
PEXELS_KEYWORD_DELAY_MS=500

# ---- Storage ----
DATABASE_URL=file:./data/news.db

# ---- Scheduler ----
NEWS_INTERVAL_MINUTES=60
SCHEDULER_ENABLED=false
RUN_ON_START=false
AUTO_PUBLISH=false
NEWS_MAX_PER_RUN=5

# ---- Website/API server ----
SERVER_HOST=127.0.0.1
PORT=3000
SITE_VERSION=2
# หากเว้นว่าง Admin API จะปิดใช้งาน
ADMIN_TOKEN=

# ---- Scraper tuning ----
# จำนวนข่าวสูงสุดต่อหน้าหมวดที่จะดึงในแต่ละรอบ
KITCO_MAX_PER_SECTION=20
# อายุข่าวสูงสุดที่จะรับ (ชั่วโมง) — ข่าวเก่ากว่านี้จะถูกตัดออก
KITCO_MAX_AGE_HOURS=48
# หน่วงเวลาระหว่างการเปิดบทความ (ms) เพื่อ rate limit
KITCO_ARTICLE_DELAY_MS=1500
# HTTP timeout (ms)
KITCO_HTTP_TIMEOUT_MS=20000
# จำนวน retry เมื่อ request ล้มเหลว
KITCO_HTTP_RETRIES=2

# ---- Logging ----
LOG_LEVEL=info
