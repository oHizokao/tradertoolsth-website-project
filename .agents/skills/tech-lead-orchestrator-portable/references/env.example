# Copy to a local ignored file or set these values in the process environment.
ANTHROPIC_BASE_URL=https://your-anthropic-compatible-provider.example/anthropic
ANTHROPIC_AUTH_TOKEN=replace-with-a-new-token
ANTHROPIC_MODEL=glm-5.2
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_EFFORT_LEVEL=max

# Optional overrides
# CLAUDE_CLI_COMMAND=claude
# ORCHESTRATOR_HEARTBEAT_SECONDS=60
